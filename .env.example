# ============================================================
# Supabase — Settings → API w panelu Supabase
# ============================================================
NEXT_PUBLIC_SUPABASE_URL=https://TWOJ_PROJEKT.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=TWOJ_ANON_KEY
SUPABASE_SERVICE_ROLE_KEY=TWOJ_SERVICE_ROLE_KEY

# ============================================================
# App URL — na Vercel zmień na https://twoja-domena.vercel.app
# ============================================================
NEXT_PUBLIC_APP_URL=http://localhost:3000

# ============================================================
# Email — Resend (resend.com → API Keys)
# ============================================================
RESEND_API_KEY=re_TWOJ_KLUCZ
RESEND_FROM_EMAIL=hej@twojafirma.pl
RESEND_FROM_NAME=AutomationHub
RESEND_WEBHOOK_SECRET=whsec_TWOJ_SEKRET_Z_RESEND

# ============================================================
# AI — Anthropic (console.anthropic.com → API Keys)Do
# ============================================================
ANTHROPIC_API_KEY=sk-ant-TWOJ_KLUCZ

# ============================================================
# AI — Google Gemini (opcjonalnie, aistudio.google.com)
# ============================================================
GEMINI_API_KEY=AIza_TWOJ_KLUCZ

# ============================================================
# Google Service Account — do generowania dokumentów i Google Drive
# Wklej CAŁY JSON jako jedna linia (bez złamania wiersza)
# GCP Console → IAM → Service Accounts → Create Key → JSON
# ============================================================
GOOGLE_SERVICE_ACCOUNT_KEY={"type":"service_account","project_id":"..."}

# ============================================================
# Google OAuth — do integracji Google Drive (opcjonalnie)
# GCP Console → APIs & Services → Credentials
# ============================================================
GOOGLE_CLIENT_ID=TWOJ_CLIENT_ID.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=TWOJ_CLIENT_SECRET
GOOGLE_REDIRECT_URI=https://twoja-domena.vercel.app/api/integrations/google/callback

# ============================================================
# Webhooki — sekrety do weryfikacji przychodzących żądań
# ============================================================
FATHOM_WEBHOOK_SECRET=whsec_TWOJ_SEKRET_Z_FATHOM
LEADS_WEBHOOK_SECRET=LOSOWY_SEKRET_MIN_32_ZNAKI
